{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_SERVER;Port=3306;Database=loan_scrutiny_system;User ID=YOUR_USER;Password=YOUR_PASSWORD;SslMode=None;"
  },
  "JwtSettings": {
    "Secret": "YOUR_SUPER_SECRET_KEY_MIN_32_CHARS"
  },
  "RocketPay": {
    "BaseUrl": "https://api-staging.rocketpay.co.in",
    "AppContext": "MERCHANT_API",
    "Token": "YOUR_ROCKETPAY_TOKEN"
  },
  "ExternalServices": {
    "ProxyBaseUrl": "http://YOUR_PROXY_URL"
  }
}
